; The project mixes Capacitor 7 with plugins that declare older/newer core peer
; ranges (e.g. @perfood/capacitor-healthkit wants ^4, @capgo/capacitor-social-login
; wants >=7). They work at runtime; this keeps `npm install` / `npm ci` (local + CI)
; from failing on the peer-range mismatch.
legacy-peer-deps=true
